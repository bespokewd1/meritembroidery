---
// src/components/TrustBadge/TrustBadgeSection.astro
import { Image } from "astro:assets";

import years from "@assets/images/30years.png";
import canada from "@assets/images/canada.png";
import attention from "@assets/images/attention.png";
import onestop from "@assets/images/onestop.png";
import satisfaction from "@assets/images/satisfaction.png";

const badges: ImageMetadata[] = [
  onestop,
  attention,
  years,
  canada,
  satisfaction,
];
---

<!-- ============================================ -->
<!--                Trust badges                  -->
<!-- ============================================ -->
<section class="relative z-2 w-full px-4 pb-16 pt-0 md:px-8">
  <div class="mb-10 w-full text-center">
    <h2
      class="font-acumin font-medium  max-w-7xl mx-auto tracking-wide text-pretty text-white text-header"
    >
      Experience, Quality And Delivery You Can Count On!
    </h2>
  </div>

  <!-- Badges -->
  <div
    class="flex w-full flex-wrap max-w-280 mx-auto items-center justify-center gap-6 sm:gap-8 md:flex-nowrap md:justify-between "
  >
    {
      badges.map((badge) => (
        <div class="flex w-24 max-w-40 items-center justify-center sm:w-28 md:w-full">
          <Image
            src={badge}
            alt="Trust badge"
            class="aspect-square w-full object-contain drop-shadow-md"
          />
        </div>
      ))
    }
  </div>
</section>