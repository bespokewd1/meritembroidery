---
import { type HTMLAttributes } from "astro/types";
import cn from "@utils/cn";
import { Image } from "astro:assets";

type ServiceSubtype = {
  image: ImageMetadata;
  label: string;
};

type Props = HTMLAttributes<"section"> & {
  imageSrc?: ImageMetadata;
  imageSlides?: ImageMetadata[];
  imageAlt: string;
  isReverse?: boolean;
  features?: string[];
  subtypes?: ServiceSubtype[];
  galleryHref?: string;
};

const {
  id: anchorId,
  imageSrc,
  imageSlides = [],
  imageAlt,
  isReverse = false,
  features = [],
  subtypes = [],
  galleryHref = "/portfolio",
  class: className,
  ...props
} = Astro.props;

const slides =
  imageSlides.length > 0 ? imageSlides : imageSrc ? [imageSrc] : [];
---

<section
  id={anchorId}
  class:list={cn(
    "bg-bg-light mx-auto max-w-360 scroll-mt-18 px-4 py-12 sm:px-6 lg:scroll-mt-29 lg:px-8 lg:py-16",
    className,
  )}
  {...props}
>
  <div class="mx-auto flex w-full flex-col gap-8 lg:gap-12">
    <!-- TOP SECTION: Arch Image & Subtype Cards -->
    <div
      class:list={cn(
        "flex flex-col gap-8 lg:max-h-150 lg:flex-row lg:items-stretch lg:gap-10",
        isReverse && "lg:flex-row-reverse",
      )}
    >
      <!-- Arch Image Area -->
      <div
        class="service-arch relative aspect-[20/16] w-full shrink-0 overflow-hidden rounded-t-full lg:w-1/2"
        data-service-arch-carousel
      >
        <div class="embla__viewport h-full" data-embla-viewport>
          <div class="embla__container flex h-full">
            {
              slides.map((slide, index) => (
                <div class="embla__slide relative min-w-0 flex-[0_0_100%]">
                  <Image
                    src={slide}
                    alt={index === 0 ? imageAlt : ""}
                    class="size-full object-cover"
                    widths={[400, 800, 1200]}
                    sizes="(max-width: 1024px) 100vw, 50vw"
                    loading={index === 0 ? "eager" : "lazy"}
                  />
                </div>
              ))
            }
          </div>
        </div>

        <div
          class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"
        >
        </div>

        <h2
          class:list={[
            "text-shadow-accent-primary text-header absolute bottom-8 z-10 font-bold tracking-wide text-balance text-white text-shadow-lg/100",
            isReverse
              ? "left-8 text-left sm:left-12"
              : "right-8 text-right sm:right-12",
          ]}
        >
          <slot name="title" />
        </h2>
      </div>

      <!-- Subtypes Cards Grid Area -->
      {
        subtypes.length > 0 && (
          <div class="my-auto grid w-full grid-cols-1 gap-4 sm:grid-cols-2 lg:my-0 lg:w-1/2">
            {subtypes.map((subtype, index) => {
              // Expand the last item if the total amount of cards is odd
              const isOddLast =
                subtypes.length % 2 !== 0 && index === subtypes.length - 1;
              return (
                <div
                  class:list={[
                    "border-accent-light relative max-h-[165px] overflow-hidden rounded-lg border-2 bg-white text-center md:max-h-[200px] lg:max-h-full",
                    isOddLast ? "sm:col-span-2" : "",
                  ]}
                >
                  {/* isOddLast ? "aspect-12/5 sm:aspect-24/5" : "aspect-12/5", */}

                  {/* isOddLast
                        ? "aspect-12/5 sm:aspect-video"
                        : "aspect-square", */}

                  {/* isOddLast ? "aspect-12/5 sm:aspect-24/5" : "aspect-12/5", */}
                  {/* aspect-square  */}
                  <div class:list={["relative size-full overflow-hidden"]}>
                    <Image
                      src={subtype.image}
                      alt={subtype.label}
                      widths={[300, 600]}
                      class="size-full object-cover"
                      sizes="(max-width: 640px) 100vw, 50vw"
                    />
                    {/* pt-8 pb-3 */}
                    <div class="absolute inset-x-0 bottom-0 z-10 bg-linear-to-t from-black/90 via-black/70 to-transparent px-2 py-1">
                      <div
                        class="pointer-events-none absolute inset-0 -z-10 h-[200%] w-full backdrop-blur-sm"
                        style="mask: linear-gradient(to bottom, rgba(255, 255, 255) 0% 50%, transparent 50% 100%); -webkit-mask: linear-gradient(to bottom, rgba(255, 255, 255) 0% 50%, transparent 50% 100%);"
                      />

                      <div
                        class="pointer-events-none absolute inset-0 h-full -translate-y-full bg-white/10"
                        style="mask: linear-gradient(to top, black 0, black 6px, transparent 6px); -webkit-mask: linear-gradient(to top, black 0, black 6px, transparent 6px); backdrop-filter: blur(4px) brightness(120%); margin-top: 1px;"
                      />

                      <div class="relative z-10">
                        <p class="text-body-light mt-2 flex flex-1 items-center justify-center text-xl font-bold">
                          {subtype.label}
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        )
      }
    </div>

    <!-- Description & Feature List Lines -->
    <div class="flex flex-col gap-6">
      <!-- Description -->
      <div class="text-accent-dark/80 text-body max-w-none font-medium">
        <slot name="description" />
      </div>

      <!-- Features grid list -->
      {
        features.length > 0 && (
          <div class="mt-2 grid grid-cols-1 gap-x-12 gap-y-4 sm:grid-cols-2">
            {features.map((feature) => (
              <div class="border-accent-light text-accent-dark text-body border-b-[3px] pb-2 font-bold">
                {feature}
              </div>
            ))}
          </div>
        )
      }
    </div>

    <!-- CTA Button -->
    <div class="mt-4 flex items-center justify-center lg:mt-6">
      <a
        href="/get-a-quote"
        class="cs-button-solid bg-accent-primary h-auto px-6 py-4 text-xl font-medium tracking-widest uppercase"
      >
        Get a Quote
      </a>
    </div>
  </div>
</section>

<script>
  import EmblaCarousel from "embla-carousel";
  import Autoplay from "embla-carousel-autoplay";

  document.addEventListener("astro:page-load", () => {
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const roots = document.querySelectorAll("[data-service-arch-carousel]");

    roots.forEach((root) => {
      if (!(root instanceof HTMLElement)) return;
      if (root.dataset.emblaInitialized === "true") return;

      const viewport = root.querySelector("[data-embla-viewport]");
      if (!(viewport instanceof HTMLElement)) return;

      const slideCount = root.querySelectorAll(".embla__slide").length;
      const shouldAutoplay = !prefersReducedMotion && slideCount > 1;

      EmblaCarousel(
        viewport,
        {
          loop: slideCount > 1,
        },
        shouldAutoplay
          ? [
              Autoplay({
                delay: 3000,
                stopOnInteraction: false,
                stopOnMouseEnter: true,
                stopOnFocusIn: true,
              }),
            ]
          : [],
      );

      root.dataset.emblaInitialized = "true";
    });
  });
</script>
