---
import { type HTMLAttributes } from "astro/types";
import cn from "@utils/cn";
import { Image } from "astro:assets";
import ButtonLink from "./Ui/ButtonLink.astro";

type ServiceSubtype = {
  image: ImageMetadata;
  label: string;
};

type Props = HTMLAttributes<"section"> & {
  imageSrc: ImageMetadata;
  imageAlt: string;
  isReverse?: boolean;
  features?: string[];
  subtypes?: ServiceSubtype[];
  galleryHref?: string;
};

const {
  id: anchorId,
  imageSrc,
  imageAlt,
  isReverse = false,
  features = [],
  subtypes = [],
  galleryHref = "/gallery",
  class: className,
  ...props
} = Astro.props;
---

<section
  id={anchorId}
  class:list={cn(
    "bg-bg-light scroll-mt-18 px-4 py-12 sm:px-6 lg:scroll-mt-29 lg:px-8 lg:py-16",
    className,
  )}
  {...props}
>
  <div
    class:list={cn(
      "mx-auto flex max-w-7xl flex-col gap-8 lg:flex-row lg:gap-10",
      isReverse && "lg:flex-row-reverse",
    )}
  >
    <!-- Main content area -->
    <div class="min-w-0 flex-1">
      <!-- Hero image with arch clip + title overlay -->
      <div
        class:list={cn(
          "relative aspect-4/3 w-full overflow-hidden rounded-t-full",
        )}
      >
        <Image
          src={imageSrc}
          alt={imageAlt}
          class="size-full object-cover"
          widths={[400, 800, 1200]}
          sizes="(max-width: 768px) 100vw, 60vw"
        />
        <!-- Gradient overlay -->
        <div
          class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"
        >
        </div>
        <!-- Title on image -->
        <h2
          class:list={cn(
            "text-shadow-accent-primary absolute bottom-6 text-right text-[clamp(2.25rem,3vw+1rem,4.5rem)] font-bold tracking-wide text-balance text-white text-shadow-lg/100",
            isReverse ? "left-8 sm:left-12" : "right-8 sm:right-12",
          )}
        >
          <slot name="title" />
        </h2>
      </div>

      <!-- Description -->
      <div class="text-accent-dark/80 mt-6">
        <slot name="description" />
      </div>

      <!-- Features grid -->
      {
        features.length > 0 && (
          <div class="mt-5 grid grid-cols-1 gap-x-6 gap-y-3 sm:grid-cols-2">
            {features.map((feature) => (
              <div class="border-accent-light text-accent-dark border-b-[3px] pb-2 text-sm font-semibold">
                {feature}
              </div>
            ))}
          </div>
        )
      }

      <!-- CTA -->
      <div class="mt-8 flex items-center justify-center">
        <ButtonLink href="/contactUs">Get a Quote</ButtonLink>
      </div>
    </div>

    <!-- Service subtypes sidebar -->
    {
      subtypes.length > 0 && (
        <div class="flex w-full shrink-0 flex-col gap-4 lg:w-64 xl:w-72">
          {subtypes.map((subtype) => (
            <div class="border-accent-light overflow-hidden rounded-lg border-2 bg-white p-3 text-center transition-shadow hover:shadow-lg">
              <div class="mx-auto aspect-4/3 w-fit overflow-hidden rounded">
                <Image
                  src={subtype.image}
                  alt={subtype.label}
                  class="size-full object-cover"
                  widths={[150, 300]}
                  sizes="150px"
                />
              </div>
              <p class="text-accent-dark mt-2 text-sm font-bold">
                {subtype.label}
              </p>
            </div>
          ))}

          <div class="pt-2 text-right">
            <a
              href={galleryHref}
              class="cs-button-solid bg-accent-primary font-poppins mx-auto h-auto py-3 leading-4 font-medium tracking-wider"
            >
              View Our Full
              <br />
              <span class="text-2xl leading-5 tracking-widest">Gallery</span>
            </a>
          </div>
        </div>
      )
    }
  </div>
</section>
