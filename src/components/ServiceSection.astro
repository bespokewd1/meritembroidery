---
import { type HTMLAttributes } from "astro/types";
import cn from "@utils/cn";
import { Image } from "astro:assets";

type ServiceSubtype = {
  image: ImageMetadata;
  label: string;
};

type Props = HTMLAttributes<"section"> & {
  imageSrc: ImageMetadata;
  imageAlt: string;
  isReverse?: boolean;
  features?: string[];
  subtypes?: ServiceSubtype[];
  galleryHref?: string;
};

const {
  id: anchorId,
  imageSrc,
  imageAlt,
  isReverse = false,
  features = [],
  subtypes = [],
  galleryHref = "/portfolio",
  class: className,
  ...props
} = Astro.props;
---

<section
  id={anchorId}
  class:list={cn(
    "bg-bg-light mx-auto max-w-360 scroll-mt-18 px-4 py-12 sm:px-6 lg:scroll-mt-29 lg:px-8 lg:py-16",
    className,
  )}
  {...props}
>
  <div class="mx-auto flex w-full flex-col gap-8 lg:gap-12">
    <!-- TOP SECTION: Arch Image & Subtype Cards -->
    <div
      class:list={cn(
        "flex flex-col gap-8 lg:flex-row lg:items-start lg:gap-10",
        isReverse && "lg:flex-row-reverse",
      )}
    >
      <!-- Arch Image Area -->
      <div
        class="relative aspect-[20/16] w-full shrink-0 overflow-hidden rounded-t-full lg:w-1/2"
      >
        <Image
          src={imageSrc}
          alt={imageAlt}
          class="size-full object-cover"
          widths={[400, 800, 1200]}
          sizes="(max-width: 1024px) 100vw, 50vw"
        />
        <!-- Gradient overlay -->
        <div
          class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"
        >
        </div>
        <!-- Title on image -->
        <!-- text-[clamp(2.25rem,3vw+1rem,4.5rem)]  -->
        <h2
          class:list={[
            "text-shadow-accent-primary text-header absolute bottom-8 font-black tracking-wide text-balance text-white text-shadow-lg/100",
            isReverse
              ? "left-8 text-left sm:left-12"
              : "right-8 text-right sm:right-12",
          ]}
        >
          <slot name="title" />
        </h2>
      </div>

      <!-- Subtypes Cards Grid Area -->
      {
        subtypes.length > 0 && (
          <div class="my-auto grid w-full grid-cols-1 gap-4 sm:grid-cols-2 lg:w-1/2">
            {subtypes.map((subtype, index) => {
              // Expand the last item if the total amount of cards is odd
              const isOddLast =
                subtypes.length % 2 !== 0 && index === subtypes.length - 1;
              return (
                <div
                  class:list={[
                    "border-accent-light flex flex-col justify-center overflow-hidden rounded-lg border-2 bg-white p-3 text-center transition-shadow hover:shadow-lg",
                    isOddLast ? "sm:col-span-2" : "",
                  ]}
                >
                  <div
                    class:list={[
                      "mx-auto w-full overflow-hidden rounded",
                      // 3:1 aspect ratio standard. If stretched across 2 columns, 6:1 keeps the height uniform.
                      isOddLast ? "aspect-3/1 sm:aspect-6/1" : "aspect-3/1",
                    ]}
                  >
                    <Image
                      src={subtype.image}
                      alt={subtype.label}
                      class="size-full object-cover"
                      widths={[300, 600]}
                      sizes="(max-width: 640px) 100vw, 50vw"
                    />
                  </div>
                  <p class="text-accent-dark text-title mt-2 flex flex-1 items-center justify-center font-black">
                    {subtype.label}
                  </p>
                </div>
              );
            })}
          </div>
        )
      }
    </div>

    <!-- Description & Feature List Lines -->
    <div class="flex flex-col gap-6">
      <!-- Description -->
      <div class="text-accent-dark/80 text-body max-w-none font-medium">
        <slot name="description" />
      </div>

      <!-- Features grid list -->
      {
        features.length > 0 && (
          <div class="mt-2 grid grid-cols-1 gap-x-12 gap-y-4 sm:grid-cols-2">
            {features.map((feature) => (
              <div class="border-accent-light text-accent-dark text-body border-b-[3px] pb-2 font-black">
                {feature}
              </div>
            ))}
          </div>
        )
      }
    </div>

    <!-- CTA Button -->
    <div class="mt-4 flex items-center justify-center lg:mt-6">
      <a
        href="/get-a-quote"
        class="cs-button-solid bg-accent-primary h-auto px-6 py-4 text-xl font-normal tracking-widest uppercase"
      >
        Get a Quote
      </a>
    </div>
  </div>
</section>
