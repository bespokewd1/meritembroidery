---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { type HTMLAttributes } from "astro/types";
import cn from "@utils/cn";

import ButtonLink from "./Ui/ButtonLink.astro";

export interface AppLogo {
  src: ImageMetadata;
  alt: string;
  calcWidth: number;
}

const imageHeight = "h-[250px]";

type Props = HTMLAttributes<"section"> & {
  images: AppLogo[];
  carouselDuration?: `${number}s`;
};
const {
  class: className,
  images,
  carouselDuration = "15s",
  ...props
} = Astro.props;
---

<section
  class:list={[
    cn(
      "corner-squircle border-accent-primary relative overflow-hidden rounded-[100px] border-4 bg-white p-(--sectionPadding) lg:py-10 supports-[corner-shape:squircle]:rounded-[150px]",
      "mx-[min(3vw,0.5rem)] lg:min-h-[50dvh]",
      className,
    ),
  ]}
  {...props}
>
  <div class="mx-auto">
    <span class="cs-topper text-topper text-center font-medium tracking-wider"
      >Gallery</span
    >
    <h2 class="cs-title text-accent-dark text-header text-center font-black">
      Showcasing Our Finest Creations
    </h2>

    <!-- Logos Carousel -->
    <div
      class="scrollbar-hide mask-bg-3 relative mx-auto my-8 flex w-full items-center justify-end"
    >
      {
        [...Array(2)].map((_, i) => (
          <div
            aria-hidden={i === 1}
            class="animate-move-to-right grid auto-cols-[1fr] grid-flow-col grid-rows-1 gap-16 pl-16"
            style={`animation-duration: ${carouselDuration} !important;`}
          >
            {images
              .slice(0, images.length / 2)
              .map(({ src, alt, calcWidth }) => (
                // <div
                //   class:list={["flex items-center justify-center", imageHeight]}
                //   style={`width: ${calcWidth}px;`}
                // >
                <div
                  class:list={[
                    "flex aspect-4/3 items-center justify-center",
                    imageHeight,
                  ]}
                >
                  <Image src={src} alt={alt} class="size-full object-contain" />
                </div>
              ))}
          </div>
        ))
      }
    </div>

    <div
      class="scrollbar-hide mask-bg-3 relative mx-auto flex w-full items-center justify-start"
    >
      {
        [...Array(2)].map((_, i) => (
          <div
            aria-hidden={i === 1}
            class="animate-move-to-left grid auto-cols-[1fr] grid-flow-col grid-rows-1 gap-16 pr-16"
            style={`animation-duration: ${carouselDuration} !important;`}
          >
            {images.slice(images.length / 2).map(({ src, alt, calcWidth }) => (
              // style={`width: ${calcWidth}px;`}
              <div
                class:list={[
                  "flex aspect-4/3 items-center justify-center",
                  imageHeight,
                ]}
              >
                <Image src={src} alt={alt} class="size-full object-contain" />
              </div>
            ))}
          </div>
        ))
      }
    </div>
    <div class="mt-6 flex items-center justify-center">
      <ButtonLink
        class="mx-auto h-auto py-3 leading-4 font-medium tracking-wider"
        href="/portfolio"
      >
        View Our Full
        <br />
        <span class="text-2xl leading-5 tracking-widest">Gallery</span>
      </ButtonLink>
    </div>
  </div>

  <!-- <Image
    src={appBg}
    class="xs:scale-200 absolute top-1/2 left-1/2 -z-1 -translate-1/2 scale-300 sm:scale-160 md:scale-130 lg:scale-90"
    alt={"blurred bg"}
  /> -->
</section>
