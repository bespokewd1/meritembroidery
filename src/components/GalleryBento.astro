---
import { getImage } from "astro:assets";
import GalleryBentoReact, { type GalleryImage } from "./GalleryBentoReact";
import {
  getGalleryImagesByFolders,
  type GalleryFolder,
} from "@data/galleryImage";

interface Props {
  folders?: GalleryFolder[];
}

const {
  folders = [
    "applique",
    "digital",
    "embroidery",
    "engraving",
    "new",
    "patches",
    "screenprint",
  ],
} = Astro.props;

const rawImages = getGalleryImagesByFolders(folders);

const optimizedImages: GalleryImage[] = await Promise.all(
  rawImages.map(async ({ image, title }, index) => {
    const ratio = image.width / image.height;

    let spanClass = "md:col-span-1";
    let imgClass = "object-cover";
    let targetWidth = 900;

    if (ratio > 1.6) {
      spanClass = "md:col-span-2";
      imgClass = "";
      targetWidth = 1400;
    } else if (ratio < 0.9) {
      spanClass = "md:row-span-2";
      imgClass = "";
      targetWidth = 900;
    }

    const optimized = await getImage({
      src: image,
      format: "webp",
      quality: 80,
      width: Math.min(image.width, targetWidth),
    });

    return {
      src: optimized.src,
      width: optimized.attributes.width,
      height: optimized.attributes.height,
      alt: title || `Portfolio image ${index + 1}`,
      spanClass,
      imgClass,
      title,
    };
  }),
);
---

<GalleryBentoReact images={optimizedImages} client:visible />
