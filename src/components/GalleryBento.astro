---
import { rawImages } from "@data/galleryImage";
import { getImage } from "astro:assets";
import GalleryBentoReact, { type GalleryImage } from "./GalleryBentoReact";

const getCleanTitle = (src: string) => {
  // Grab filename from path and strip queries
  let filename = src.split("/").pop()?.split("?")[0] || "";

  // Remove file extension
  let nameOnly = filename.substring(0, filename.lastIndexOf(".")) || filename;

  // Remove Astro's production hash if present (usually looks like 'filename.1a2b3c4d')
  const parts = nameOnly.split(".");
  if (parts.length > 1 && parts[parts.length - 1].length >= 8) {
    parts.pop();
  }

  // Replace dashes/underscores with spaces and Capitalize Words
  return parts
    .join(".")
    .replace(/[-_]/g, " ")
    .split(" ")
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
};

const optimizedImages: GalleryImage[] = await Promise.all(
  rawImages.map(async (img, index) => {
    const ratio = img.width / img.height;

    let spanClass = "md:col-span-1";
    let imgClass = "object-cover";
    let targetWidth = 900;

    if (ratio > 1.6) {
      spanClass = "md:col-span-2";
      imgClass = "";
      targetWidth = 1400;
    } else if (ratio < 0.9) {
      spanClass = "md:row-span-2";
      imgClass = "";
      targetWidth = 900;
    }

    const optimized = await getImage({
      src: img,
      format: "webp",
      quality: 80,
      width: Math.min(img.width, targetWidth),
    });

    return {
      src: optimized.src,
      width: optimized.attributes.width,
      height: optimized.attributes.height,
      alt: `Portfolio image ${index + 1}`,
      spanClass,
      imgClass,
      title: getCleanTitle(img.src),
    };
  }),
);
---

<GalleryBentoReact images={optimizedImages} client:visible />
