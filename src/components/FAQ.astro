---
import client from "@data/client.json";
import faqImg from "@assets/images/FAQs.png";
import { Image } from "astro:assets";

type FaqItem = {
  question: string;
  answerHtml: string;
  open?: boolean;
};

const faqs: FaqItem[] = [
  {
    question: "What products can you customize?",
    open: true,
    answerHtml: `
      We customize apparel such as t-shirts, hoodies, jackets, hats, bags,
      and uniforms, as well as promotional items. Have something specific?
      Email
      <a class="hover:text-body-dark font-medium" href="mailto:info@meritembroidery.com">
        info@meritembroidery.com
      </a>
      or call
      <a class="hover:text-body-dark font-medium" href="tel:${client.phoneForTel}">
        ${client.phoneFormatted}
      </a> /
      <a class="hover:text-body-dark font-medium" href="tel:${client.phoneForTel2}">
        ${client.phoneFormatted2}
      </a>.
    `,
  },
  {
    question: "How do I get a quote?",
    answerHtml: `
      You can email, call, or use our Get a Quote form. We will review your
      request and send a personalized quote.
    `,
  },
  {
    question: "What file formats do you accept?",
    answerHtml: `
      We accept PNG, JPEG, PDF, AI, and EPS files. Need help? Contact us and
      we’ll assist you.
    `,
  },
  {
    question: "How long does it take to complete an order?",
    answerHtml: `
      Turnaround time depends on the size and complexity of the order. Small
      orders typically take [X] days, and larger orders may take [X–X] weeks.
      Rush orders may be possible — just reach out.
    `,
  },
  {
    question: "Can I request a proof?",
    answerHtml: `
      Yes! Digital proofs are provided for review before production.
      Adjustments can be made as needed.
    `,
  },
];
---

<section
  id="faq-351"
  class:list={[
    "bg-bg-light relative before:mr-[max(5vw,2rem)]",
    "before:bg-accent-primary before:absolute before:inset-0 before:max-w-400 before:rounded-r-[20vw] before:lg:rounded-r-full",
  ]}
>
  <Image
    src={faqImg}
    class:list={[
      "absolute inset-0 aspect-square size-full max-w-400 object-contain object-right",
    ]}
    alt={"3 blue question mark in red background"}
  />

  <!-- max-w-137.5
lg:max-w-7xl  -->
  <!-- <div class="absolute bg-accent-light rounded-r-[20vw] inset-0 -z-1 "></div> -->
  <div
    class:list={[
      "relative isolate flex w-full max-w-360 flex-col items-center gap-12 pt-8 pr-[max(5vw,2rem)] pb-20 pl-2 lg:mx-auto",
      "lg:items-start lg:justify-between lg:rounded-r-full lg:pb-8 lg:pl-8",
    ]}
  >
    <!-- max-w-212.5  -->
    <div class="flex w-full flex-col items-start text-left">
      <span class="text-topper text-body-light font-medium tracking-wider">
        Frequently Asked Questions
      </span>

      <h2 class="text-header text-body-light font-medium">
        You have Questions? <br /> We have Answers!
      </h2>
    </div>

    <ul class="w-full max-w-212.5 p-0 lg:w-[60%]">
      {
        faqs.map((faq, index) => (
          <li
            class:list={[
              "max-w-212 list-none border-b border-neutral-200",
              index === faqs.length - 1 && "border-b-0",
            ]}
          >
            <details
              class:list={[
                "group overflow-hidden border-l-4 border-transparent transition-colors duration-300 ease-in",
                "open:text-body-dark open:border-primary open:bg-white",
              ]}
              open={faq.open}
            >
              <summary
                class:list={[
                  "text-body-light flex cursor-pointer list-none items-start justify-between gap-4 px-4 py-4 text-left text-2xl leading-tight font-medium transition-colors duration-300 [&::-webkit-details-marker]:hidden",
                  "group-open:text-body-dark",
                  // "group-open:text-body-dark group-open:border-primary group-open:border-l-4 group-open:bg-white",
                ]}
              >
                <span class="text-title block p-1">{faq.question}</span>

                <svg
                  class="mt-1 h-5 w-5 shrink-0 transition-transform duration-300 group-open:rotate-180"
                  viewBox="0 0 20 20"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="m6 8 4 4 4-4" />
                </svg>
              </summary>

              <div
                class:list={[
                  "block opacity-0",
                  "group-open:text-body-dark transition-opacity group-open:opacity-100",
                ]}
              >
                <div class="overflow-hidden">
                  <div
                    class="text-body text-body-light group-open:text-body-dark px-4 pb-6 leading-7 opacity-0 transition-[opacity,color] duration-300 group-open:opacity-100 [&_a]:underline [&_a]:underline-offset-4 [&_a]:transition-opacity hover:[&_a]:opacity-80"
                    set:html={faq.answerHtml}
                  />
                </div>
              </div>
            </details>
          </li>
        ))
      }
    </ul>

    <p class="text-title text-body-light">
      Still have questions? Give us a <a
        href={`tel:${client.phoneForTel}`}
        class="text-primary text-title hover:text-body-light underline transition-colors"
        >call!</a
      >
    </p>
  </div>
</section>

<style>
  .starting-slide-in {
    transition:
      opacity 300ms ease-in,
      display 300ms ease-in !important;
    transition-behavior: allow-discrete !important;

    @starting-style {
      opacity: 0;
      display: none;
    }
  }
</style>
