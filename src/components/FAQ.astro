---
import client from "@data/client.json";

type FaqItem = {
  question: string;
  answerHtml: string;
  open?: boolean;
};

const faqs: FaqItem[] = [
  {
    question: "What products can you customize?",
    open: true,
    answerHtml: `
      We customize apparel such as t-shirts, hoodies, jackets, hats, bags,
      and uniforms, as well as promotional items. Have something specific?
      Email
      <a class="hover:text-body-dark font-medium" href="mailto:info@meritembroidery.com">
        info@meritembroidery.com
      </a>
      or call
      <a class="hover:text-body-dark font-medium" href="tel:${client.phoneForTel}">
        ${client.phoneFormatted}
      </a> / 
      <a class="hover:text-body-dark font-medium" href="tel:${client.phoneForTel2}">
        ${client.phoneFormatted2}
      </a>.
    `,
  },
  {
    question: "How do I get a quote?",
    answerHtml: `
      You can email, call, or use our Get a Quote form. We will review your
      request and send a personalized quote.
    `,
  },
  {
    question: "What file formats do you accept?",
    answerHtml: `
      We accept PNG, JPEG, PDF, AI, and EPS files. Need help? Contact us and
      we’ll assist you.
    `,
  },
  {
    question: "How long does it take to complete an order?",
    answerHtml: `
      Turnaround time depends on the size and complexity of the order. Small
      orders typically take [X] days, and larger orders may take [X–X] weeks.
      Rush orders may be possible — just reach out.
    `,
  },
  {
    question: "Can I request a proof?",
    answerHtml: `
      Yes! Digital proofs are provided for review before production.
      Adjustments can be made as needed.
    `,
  },
];
---

<section id="faq-351" class="bg-bg-light pr-[max(5vw,2rem)]">
  <div
    class:list={[
      "ml-0 flex w-full max-w-137.5 flex-col items-center gap-12 rounded-r-[20vw] bg-accent-light pt-8 pb-20 pl-2",
      " lg:max-w-7xl lg:items-start lg:justify-between lg:rounded-r-full lg:pb-8 lg:pl-8",
    ]}
  >
    <div class="flex w-full flex-col items-start text-left">
      <span class="text-topper text-primary font-medium tracking-wider">
        Frequently Asked Questions
      </span>

      <h2 class="text-header text-body-light font-black">
        You have Questions? <br /> We have Answers!
      </h2>
    </div>

    <ul class="w-full p-0 lg:w-[60%]">
      {
        faqs.map((faq, index) => (
          <li
            class:list={[
              "list-none border-b border-neutral-200",
              index === faqs.length - 1 && "border-b-0",
            ]}
          >
            <details
              class="group transition-colors duration-300"
              open={faq.open}
            >
              <summary class="text-body-light group-open:bg-primary flex cursor-pointer list-none items-start justify-between gap-4 px-4 py-4 text-left text-2xl leading-tight font-bold transition-colors duration-300 [&::-webkit-details-marker]:hidden">
                <span class="text-title block w-[80%]">{faq.question}</span>

                <svg
                  class="mt-1 h-5 w-5 shrink-0 transition-transform duration-300 group-open:rotate-180"
                  viewBox="0 0 20 20"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="m6 8 4 4 4-4" />
                </svg>
              </summary>

              <div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-in-out group-open:grid-rows-[1fr]">
                <div class="overflow-hidden">
                  <div
                    class="text-body text-body-light p-4 pb-6 leading-7 opacity-0 transition-[padding,opacity] duration-300 group-open:pb-6 group-open:opacity-100 [&_a]:underline [&_a]:underline-offset-4 [&_a]:transition-opacity hover:[&_a]:opacity-80"
                    set:html={faq.answerHtml}
                  />
                </div>
              </div>
            </details>
          </li>
        ))
      }
    </ul>

    <div>
      <p class="text-title text-body-light">
        Still have questions? Give us a <a
          href={`tel:${client.phoneForTel}`}
          class="text-primary text-title underline transition-colors hover:text-body-light">call!</a>
      </p>
    </div>
  </div>
</section>
