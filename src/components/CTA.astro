---
import { type HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"section">;

const { class: className, ...props } = Astro.props;

import CSPicture from "@components/TemplateComponents/CSPicture.astro";
import mobileImage from "@assets/images/CTA/background-img.jpg";
import desktopImage from "@assets/images/CTA/background-img.jpg";
import ctaImg from "@assets/images/merit-cta.webp";
import fallbackImage from "@assets/images/CTA/background-img.jpg";
import ButtonLink from "./Ui/ButtonLink.astro";
import { Image } from "astro:assets";
---

<section
  id="cta"
  class:list={[
    "relative min-h-[400px] overflow-hidden md:min-h-112.5 lg:min-h-[520px]",
    className,
  ]}
  {...props}
>
  <!-- Overlay: gradient from blue-ish top to a dark scrim for readability -->
  <div
    class="pointer-events-none absolute inset-0 z-1 hidden bg-gradient-to-b from-[hsl(218,50%,65%)]/80 via-transparent to-black/30 md:bg-gradient-to-br md:from-[hsl(218,50%,65%)]/70 md:via-transparent md:to-black/20"
  >
  </div>

  <!-- Content -->
  <div
    class="relative z-10 mx-auto flex h-full max-w-full flex-col items-center px-6 pt-6 pb-12 text-center md:items-end md:px-10 md:pb-16 md:text-right lg:px-16 lg:pb-20"
  >
    <div
      class="mask-bg-both absolute top-1/2 left-1/2 -z-1 h-95 w-87.5 -translate-1/2 backdrop-blur-sm md:hidden"
    >
    </div>
    <h2
      class="text-accent-dark text-[clamp(2.25rem,3dvw+1rem,4.25rem)] leading-tight font-medium tracking-tight"
    >
      Need Custom Apparel Or
      <br />
      Promo Gear Decorated?
    </h2>
    <!-- 2.25 4.5 -->
    <p
      class="text-primary mb-8 text-[clamp(1.25rem,3dvw+1rem,2.25rem)] leading-snug font-medium italic md:mb-10"
    >
      Let&rsquo;s make it happen!
      <br />
      Fast, Reliable, and
      <br />
      Done Right.
    </p>

    <!-- <ButtonLink
      href="/get-a-quote"
      class="border-accent-dark/20! text-accent-dark! rounded-lg! border-2! bg-white/90! px-8! py-3! text-base! font-bold! tracking-wide! uppercase! shadow-lg! backdrop-blur-sm! transition-all! duration-300! hover:bg-white! hover:shadow-xl! md:text-lg!"
    >
      Get a Quote
    </ButtonLink> -->

    <ButtonLink
      class="mt-6 h-auto px-3 py-4 text-xl font-normal tracking-widest uppercase"
      href="/get-a-quote"
    >
      Get a Quote
    </ButtonLink>
  </div>

  <!-- Background Image -->
  <!-- <CSPicture
    mobileImgUrl={mobileImage}
    mobileMediaWidth="600px"
    desktopImgUrl={desktopImage}
    desktopMediaWidth="601px"
    fallbackImgUrl={fallbackImage}
    alt=""
  /> -->
  <Image
    src={ctaImg}
    alt={"cta bg"}
    class="absolute inset-0 z-0 size-full object-cover object-top-left md:object-top-right"
  />
</section>

<style>
  /* Ensure CSPicture img fills the section as a background */
  #cta :global(picture) {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
  }

  #cta :global(picture img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
  }
</style>
