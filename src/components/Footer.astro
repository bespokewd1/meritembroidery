---
import client from "@data/client.json";
import navData from "@data/navData.json";
import { getCurrentYear } from "@js/utils";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import navLogo from "@assets/images/merit-logo-only.png";

const currentYear = getCurrentYear();
const featuresBar = [
  "✓ Serving Canada Since 1992",
  "✓ State-of-the-Art Equipment",
  "✓ Fast Turnaround",
  "✓ 100% Satisfaction Guaranteed",
];
interface ContactItem {
  icon: string;
  href?: string;
  label: string;
  isLink?: boolean;
  isUppercase?: boolean;
}

const contactItems: ContactItem[] = [
  {
    icon: "tabler:map-pin",
    href: client.address.mapLink,
    label: `${client.address.lineOne}, ${client.address.lineTwo}`,
    isLink: true,
  },
  {
    icon: "tabler:phone",
    href: `tel:${client.phoneForTel}`,
    label: client.phoneFormatted,
    isLink: true,
  },
  {
    icon: "tabler:phone",
    href: `tel:${client.phoneForTel2}`,
    label: client.phoneFormatted2,
    isLink: true,
  },
  {
    icon: "tabler:building",
    label: "8:00AM-4:30PM — MON.-FRI.",
    isUppercase: true,
  },
  {
    icon: "tabler:mail",
    href: `mailto:${client.email}`,
    label: client.email,
    isLink: true,
  },
];
---

<!-- ============================================ --><!--                   Footer                     --><!-- ============================================ -->
<footer id="footer" class="bg-accent-primary font-acumin pt-10 pb-5">
  <div class="mx-auto flex w-[90%] max-w-7xl flex-col gap-4">
    <!-- Top Row: Brand & Contact -->
    <div
      class="flex flex-col justify-between gap-10 md:flex-row md:items-start"
    >
      <!-- Left: Brand, Description & Socials -->
      <div class="flex w-full flex-col items-start md:w-1/2 lg:w-1/3">
        <div class="flex items-center justify-center gap-2">
          <Image
            src={navLogo}
            alt={"merit M logo with Merit text"}
            class="aspect-square w-18 object-contain drop-shadow-sm"
          />
          <div>
            <h2 class="text-body-light text-title font-bold">
              Merit Embroidery
            </h2>
            <p class="text-body-light text-body">& Printing LTD</p>
          </div>
        </div>
        <p class="text-body-light text-body mb-6 opacity-90">
          One of the oldest and largest embroidery, printing, and promotional
          decor companies in Western Canada. Serving businesses since 1992.
        </p>

        <!-- Social Icons -->
        <ul class="flex flex-row items-center gap-4">
          <li>
            <a
              href="https://www.facebook.com/meritemb"
              class="group flex size-10 items-center justify-center rounded-full bg-black/10 transition-colors duration-300 hover:bg-red-600"
              aria-label="facebook"
              target="_blank"
              rel="noopener"
            >
              <Icon
                name="tabler:brand-facebook-filled"
                class="text-body-light size-6"
              />
            </a>
          </li>
          <li>
            <a
              href="https://www.instagram.com/meritembroidery/"
              class="group flex size-10 items-center justify-center rounded-full bg-black/10 transition-colors duration-300 hover:bg-red-600"
              aria-label="instagram"
              target="_blank"
              rel="noopener"
            >
              <Icon
                name="tabler:brand-instagram"
                class="text-body-light size-6"
              />
            </a>
          </li>
        </ul>
      </div>

      <!-- Right: Contact Info -->
      <div class="flex w-full flex-col md:w-1/2 lg:w-1/3">
        <h2
          class="text-body-light mb-4 text-lg font-bold tracking-wide uppercase"
        >
          Contact Us
        </h2>
        <ul class="text-body text-body-light flex flex-col gap-2">
          {
            contactItems.map((item, index) => (
              <li
                class:list={[
                  "flex text-[size:inherit] text-inherit",
                  index === 0 ? "items-start" : "items-center",
                ]}
              >
                <Icon
                  name={item.icon}
                  class="mr-3 h-6 w-6 shrink-0 text-inherit"
                />
                {item.isLink ? (
                  <a
                    class="text-[size:inherit] text-inherit transition-opacity hover:opacity-80"
                    href={item.href}
                  >
                    {item.label}
                  </a>
                ) : (
                  <span
                    class:list={[
                      "text-[size:inherit] text-inherit",
                      item.isUppercase ? "uppercase" : "",
                    ]}
                  >
                    {item.label}
                  </span>
                )}
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Guarantees / Features Bar -->
    <div
      class="text-body mt-2 flex w-full flex-col flex-wrap items-center justify-center border-t border-b border-white/40 py-2 md:flex-row md:items-start md:justify-around lg:px-20"
    >
      {
        featuresBar.map((bar) => (
          <p class="text-body-light text-[size:inherit]">{bar}</p>
        ))
      }
    </div>

    <!-- Bottom Footer (Copyright & Credit) -->
    <div
      class="text-body-light flex w-full flex-col items-center justify-between gap-4 text-sm md:flex-row"
    >
      <p class="text-center text-[size:inherit] text-inherit md:text-left">
        © {currentYear} Merit Embroidery & Printing LTD. All rights reserved.
      </p>
      <p class="text-center text-[size:inherit] text-inherit md:text-right">
        Digital Marketing by
        <a
          href="https://bespokewebdesign.ca/"
          class="hover:text-primary text-[size:inherit] text-inherit underline transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          Bespoke Web Design
        </a>
      </p>
    </div>
  </div>
</footer>
