---
import client from "@data/client.json";
import { getCurrentYear } from "@js/utils";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import footerLogo from "@assets/images/logo.png";

const currentYear = getCurrentYear();
const featuresBar = [
  "Serving Canada Since 1992",
  "State-of-the-Art Equipment",
  "With Experience & Expertise",
  "Fast Turnaround",
  "100% Satisfaction Guaranteed",
];
interface ContactItem {
  icon: string;
  href?: string;
  label: string;
  isLink?: boolean;
  isUppercase?: boolean;
}

const contactItems: ContactItem[] = [
  {
    icon: "tabler:map-pin",
    href: client.address.mapLink,
    label: `${client.address.lineOne}, ${client.address.lineTwo}`,
    isLink: true,
  },
  {
    icon: "tabler:phone",
    href: `tel:${client.phoneForTel}`,
    label: client.phoneFormatted,
    isLink: true,
  },
  {
    icon: "tabler:phone",
    href: `tel:${client.phoneForTel2}`,
    label: client.phoneFormatted2,
    isLink: true,
  },
  {
    icon: "tabler:building",
    label: "8:00AM-4:30PM — MON.-FRI.",
    isUppercase: true,
  },
  {
    icon: "tabler:mail",
    href: `mailto:${client.email}`,
    label: client.email,
    isLink: true,
  },
];
---

<!-- ============================================ --><!--                   Footer                     --><!-- ============================================ -->
<footer id="footer" class="bg-accent-dark font-acumin text-white">
  <div class="flex w-full flex-col">
    <div
      class="flex w-full flex-col justify-between gap-10 px-6 py-7 md:flex-row md:items-center lg:px-14"
    >
      <div class="flex w-full flex-col items-start md:w-1/2 lg:w-[48%]">
        <div
          class="flex w-full flex-col items-center gap-5 text-center sm:flex-row sm:items-center sm:text-left lg:gap-5"
        >
          <div class="footer-logo-bg relative w-32 shrink-0 lg:w-34">
            <Image
              src={footerLogo}
              alt={"Merit Embroidery & Printing logo"}
              class="relative z-10 w-full object-contain"
            />
          </div>
          <div class="flex min-w-0 flex-1 flex-col items-center sm:items-start">
            <p
              class="max-w-[21rem] text-[clamp(0.9rem,1.25vw,1.125rem)] leading-snug font-medium text-white"
            >
              One of the oldest and largest embroidery, printing, and
              promotional decoration companies. Serving customers all across
              Canada since 1992.
            </p>

            <ul class="mt-4 flex flex-row items-center gap-2">
              <li>
                <a
                  href="https://www.facebook.com/meritemb"
                  class="group flex size-7 items-center justify-center rounded-full bg-[#4069b1] transition-colors duration-300 hover:bg-red-600"
                  aria-label="facebook"
                  target="_blank"
                  rel="noopener"
                >
                  <Icon
                    name="tabler:brand-facebook-filled"
                    class="size-4 text-white"
                  />
                </a>
              </li>
              <li>
                <a
                  href="https://www.instagram.com/meritembroidery/"
                  class="group flex size-7 items-center justify-center rounded-full bg-[#4069b1] transition-colors duration-300 hover:bg-red-600"
                  aria-label="instagram"
                  target="_blank"
                  rel="noopener"
                >
                  <Icon
                    name="tabler:brand-instagram"
                    class="size-4 text-white"
                  />
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <div
        class="flex w-full flex-col items-center text-center md:w-1/2 md:items-end md:text-right lg:w-[42%]"
      >
        <h2
          class="mb-2 text-[clamp(1.25rem,2vw,1.5rem)] leading-tight font-bold tracking-wide text-white"
        >
          Contact Us
        </h2>
        <ul
          class="flex max-w-[34rem] flex-col gap-1.5 text-[clamp(0.9rem,1.15vw,1.05rem)] leading-tight font-medium text-white"
        >
          {
            contactItems.map((item) => (
              <li
                class:list={[
                  "grid grid-cols-[1fr_auto] items-center gap-3 text-[size:inherit] text-inherit",
                ]}
              >
                {item.isLink ? (
                  <a
                    class="text-[size:inherit] text-inherit transition-opacity hover:opacity-80"
                    href={item.href}
                  >
                    {item.label}
                  </a>
                ) : (
                  <span
                    class:list={[
                      "text-[size:inherit] text-inherit",
                      item.isUppercase ? "uppercase" : "",
                    ]}
                  >
                    {item.label}
                  </span>
                )}
                <span class="flex size-6 shrink-0 items-center justify-center rounded-full border border-white/90 text-white">
                  <Icon name={item.icon} class="size-4" />
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div
      class="flex w-full flex-col flex-wrap items-center justify-center gap-x-0 gap-y-2 border-t border-b border-white/35 py-3 text-center text-[clamp(0.95rem,1.25vw,1.125rem)] leading-tight md:flex-row"
    >
      {
        featuresBar.map((bar) => (
          <p class="px-4 text-[size:inherit] text-white md:border-r md:border-white/45 md:last:border-r-0">
            {bar}
          </p>
        ))
      }
    </div>

    <div
      class="flex w-full flex-col items-center justify-between gap-3 px-1 py-3 text-xs font-semibold text-white md:flex-row"
    >
      <p class="text-center text-[size:inherit] text-inherit md:text-left">
        © {currentYear} Merit Embroidery & Printing LTD. All rights reserved.
      </p>
      <p class="text-center text-[size:inherit] text-inherit md:text-right">
        Digital Marketing by
        <a
          href="https://bespokewebdesign.ca/"
          class="text-[size:inherit] text-inherit underline transition-opacity hover:opacity-80"
          target="_blank"
          rel="noopener noreferrer"
        >
          Bespoke Web Design
        </a>
      </p>
    </div>
  </div>
</footer>

<style>
  /*
  #footer .footer-logo-bg::before {
    content: "";
    position: absolute;
    inset: 8% -7% 12% -6%;
    z-index: 0;
    border-radius: 48% 52% 45% 55% / 60% 44% 56% 40%;
    background: rgba(255, 255, 255, 0.96);
    transform: rotate(-2deg);
  }
    */
  .footer-logo-bg img {
    filter: drop-shadow(1px 1px white) drop-shadow(1px -1px white)
      drop-shadow(-1px 1px white) drop-shadow(-1px -1px white);
  }
</style>
