import artwork from "@assets/images/services/artwork/Main-Photo-01.jpg";
import vectorizeLogo from "@assets/images/services/artwork/Vectorize-Logos.jpg";
import digitizeEmbroidery from "@assets/images/services/artwork/Digitize-Logos.jpg";
import editDesign from "@assets/images/services/artwork/Digitize-Logos.jpg";
import productionReady from "@assets/images/services/artwork/Vectorize-Logos.jpg";
import personalizeDesign from "@assets/images/services/artwork/Main-Photo-01.jpg";

import service1 from "@assets/images/merit-images/merit-0261.jpg";
import service2 from "@assets/images/merit-images/merit-0256.jpg";
import service3 from "@assets/images/merit-images/merit-0283.jpg";
import service4 from "@assets/images/gallery/3.jpg";
import service5 from "@assets/images/merit-images/merit-0321.jpg";
import service6 from "@assets/images/merit-images/merit-0318.jpg";

import landingImage from "@assets/images/landing.jpg";
import { getImage } from "astro:assets";
import LandingTitle from "@components/LandingTitle.astro";
import { discriminatedUnion } from "astro:schema";
const optimizedImage = await getImage({
  src: landingImage,
  format: "avif",
});
---

<BaseLayout
  title="Services | Merit Embroidery & Screen Printing"
  description="High-quality in-house embroidery, screen printing, and custom apparel decoration in Edmonton. Serving businesses across Alberta and North America with fast, reliable, and professional service."
  preloadedImage={optimizedImage}
>
  <section class="p-0 pt-16 text-center md:pt-24">
    <LandingTitle title="Our Services" />
  </section>

  <ServiceSection
    id="embroidery"
    imageSlides={[embroidery, embroidery2, embroidery3]}
    imageAlt="Custom Logo Embroidery"
    features={[
      "Flat embroidery for classic professional look",
      "3D/Puff embroidery for bold, dimensional designs",
      "FR (Flame Resistant) embroidery for safety wear",
      "Appliqué techniques for large designs",
      "Custom patches with up to 15 thread colors",
      "Compatible with apparel, headwear, bags, leather, towels",
    ]}
    subtypes={[
      { image: doubleLayer, label: "Double Layer Puff Embroidery" },
      { image: puffEmbroidery, label: "Puff Embroidery" },
      { image: frEmbroidery, label: "FR Embroidery" },
      { image: splitEmbroidery, label: "Split Front Embroidery" },
      // { image: metalEmbroidery, label: "Metallic Embroidery" },
    ]}
    galleryHref="/portfolio"
  >
    <Fragment slot="title">Embroidery</Fragment>
    <Fragment slot="description">
      <p class="text-body">
        With over three decades of experience, Merit Embroidery & Printing
        delivers premium-quality embroidery for apparel, headwear, bags,
        workwear, and more. Using Barudan multi-head commercial machines and
        in-house digitizing, we ensure every stitch meets the highest standards
        — whether it's a dozen shirts or thousands of hats.
      </p>
      <p class="text-body mt-4">
        With over 40 sewing heads, we produce thousands of embroidered goods
        daily — each piece crafted for precision, texture, and lasting impact.
      </p>
    </Fragment>
  </ServiceSection>

  <ServiceSection
    id="screen-printing"
    imageSlides={[screenPrint, screenPrint2, screenPrint3]}
    imageAlt="Screen Printing"
    features={[
      "Up to 12-color designs",
      "Reflective ink for safety wear",
      "Exact Pantone color matching",
      "Glow-in-the-dark ink options",
      "High-density prints for textured feel",
      "Water-based and plastisol inks",
    ]}
    subtypes={[
      { image: glowInDark, label: "Glow-in-the-Dark Print" },
      { image: puffPrint, label: "Puff Print" },
      { image: hdPrint, label: "HD Print" },
      { image: distressedPrint, label: "Distressed and Fashion Print" },
      { image: airPrint, label: "Air-Dry Ink Print" },
      { image: gelPrint, label: "Gel Ink Print" },
    ]}
    galleryHref="/portfolio"
  >
    <Fragment slot="title">Screen Printing</Fragment>
    <Fragment slot="description">
      <p class="text-body">
        Our state-of-the-art M&R automatic screen presses allow us to print up
        to 1,000 garments per hour, combining efficiency with exceptional
        quality. Since expanding into screen printing in 2015, we've mastered
        techniques that make every print vibrant, durable, and true to your
        brand.
      </p>
      <p class="text-body mt-4">
        We print on t-shirts, hoodies, bags, jerseys, workwear, and specialty
        fabrics, using Wilflex plastisol, water-based, and air-dry inks.
      </p>
    </Fragment>
  </ServiceSection>

  <ServiceSection
    id="digital-printing"
    imageSlides={[digitalPrint, digitalPrint2, digitalPrint3]}
    imageAlt="Digital Printing"
    features={[
      "CMYK full-color printing",
      "Sublimation printing",
      "Specialty vinyl (reflective, foil, soft foam)",
      "CAD Cut vinyl applications",
      "Direct to Film (DTF) printing",
      "High-density and debossed effects",
    ]}
    subtypes={[
      { image: colorMax, label: "Colormax Direct to Film" },
      { image: cad, label: "CAD Print/Cut" },
      { image: vinyl, label: "Specialty Vinyl" },
      { image: sublimation, label: "Sublimation" },
      { image: uvMax, label: "UV Colormax Direct to Film" },
    ]}
    galleryHref="/portfolio"
  >
    <Fragment slot="title">Digital Printing</Fragment>
    <Fragment slot="description">
      <p class="text-body">
        When your artwork requires full color and fine detail, our digital
        printing services bring it to life. Using advanced Mimaki large-format
        and DTF printers, we produce vibrant prints on apparel, headwear,
        banners, and more — all made in-house for fast turnaround and consistent
        color accuracy.
      </p>
    </Fragment>
  </ServiceSection>

  <ServiceSection
    id="laser-engraving"
    imageSlides={[engraving, engraving2, engraving3]}
    imageAlt="Laser Engraving"
    features={[
      "Precision engraving for logos and text",
      "Permanent etched finish",
      "Custom bottle and tumbler wraps",
      "Engraved glass, coasters, trophies, and medals",
      "Compatible with wood, metal, acrylic, and leather",
      "Clean detail for awards, gifts, and branded items",
    ]}
    subtypes={[
      { image: tumbler, label: "Engraved Tummblers/Bottles" },
      { image: bottle, label: "Bottle Wraps" },
      { image: glass, label: "Engraved Glass" },
      { image: coasters, label: "Engraved Coasters" },
      { image: trophies, label: "Trophies/Medals" },
    ]}
    galleryHref="/portfolio"
  >
    <Fragment slot="title">Laser Engraving</Fragment>
    <Fragment slot="description">
      <p class="text-body">
        For precise, professional customization, our laser engraving services
        etch your designs, logos, or text onto a variety of materials, including
        wood, metal, acrylic, and leather. Using advanced laser technology, we
        deliver clean, permanent results with intricate detail and sharp edges.
      </p>
    </Fragment>
  </ServiceSection>

  <ServiceSection
    id="patches"
    imageSlides={[patches, patches2, patches3]}
    imageAlt="Custom patches and crests"
    features={[
      "Intricate designs with fine detail",
      "Custom shapes and sizes",
      "Durable and professional finish",
      "Multiple fabric and material options",
      "On-demand sample production",
      "Perfect for premium branding",
    ]}
    subtypes={[
      { image: digitalPatch, label: "Digital Printed Patches" },
      { image: laserPatch, label: "Laser Engraved Patches" },
      { image: sublimatedPatch, label: "Sublimated Patches" },
      { image: embroidedPatch, label: "Embroided Patches" },
      { image: wovenPatch, label: "Woven Pathches" },
    ]}
    galleryHref="/portfolio"
  >
    <Fragment slot="title">Patches & Crests</Fragment>
    <Fragment slot="description">
      <p class="text-body">
        Custom patches and crests give uniforms, workwear, headwear, and
        promotional apparel a durable branded finish. We produce embroidered,
        woven, digital, sublimated, and laser-cut patch options in custom shapes
        and sizes.
      </p>
    </Fragment>
  </ServiceSection>

  <ServiceSection
    id="applique"
    imageSlides={[applique, applique2, applique3]}
    imageAlt="applique shirt with alberta print"
    features={[
      "Up to 12-color designs",
      "Reflective ink for safety wear",
      "Exact Pantone color matching",
      "Glow-in-the-dark ink options",
      "High-density prints for textured feel",
      "Water-based and plastisol inks",
    ]}
    subtypes={[
      { image: doubleLayerApplique, label: "Double Layer Applique" },
      { image: leatherApplique, label: "Faux Leather/Suede Applique" },
      { image: proTwillApplique, label: "Pro-Twill Applique" },
      { image: feltApplique, label: "Felt Applique" },
      { image: sublimatedApplique, label: "Sublimated Applique" },
      { image: multiMediaApplique, label: "Multi Media Applique" },
    ]}
    galleryHref="/portfolio"
  >
    <Fragment slot="title">Custom Applique</Fragment>
    <Fragment slot="description">
      <p class="text-body">
        Custom applique adds dimension and texture by stitching felt, twill,
        faux leather, suede, or mixed media pieces onto garments. It is ideal
        for oversized designs, team apparel, hoodies, and premium branded pieces
        that need a bold finish.
      </p>
    </Fragment>
  </ServiceSection>

  <ServiceSection
    id="artwork"
    imageSrc={artwork}
    imageAlt="Artwork and digitizing"
    features={[
      "Logo design and development",
      "Embroidery digitizing",
      "Screen separations",
      "Vector file creation and conversion",
      "Digital mockups and proofs",
      "Design consulting and recommendations",
    ]}
    subtypes={[
      { image: vectorizeLogo, label: "Vectorize Logos" },
      { image: digitizeEmbroidery, label: "Digitize for Embroidery" },
      { image: editDesign, label: "Edit Designs" },
      { image: productionReady, label: "Make Production-Ready Designs" },
      { image: personalizeDesign, label: "Add Text/Personalize Designs" },
    ]}
    galleryHref="/portfolio"
  >
    <Fragment slot="title">Artwork and Digitizing Services</Fragment>
    <Fragment slot="description">
      <p class="text-body font-medium">
        Our experienced in-house graphic design and digitizing team provides
        complete creative support — from logo design and mockups to vector
        files, digitizing, and embroidery file edits. Whether you need artwork
        from scratch or technical adjustments, we ensure your designs are
        optimized for perfect embroidery and printing results.
      </p>
    </Fragment>
  </ServiceSection>
  <CTA />
</BaseLayout>
