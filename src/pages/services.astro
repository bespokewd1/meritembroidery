import feltApplique from "@assets/images/services/applique/Felt-Applique.jpg";
//@ts-expect-error image extension is correct
import multiMediaApplique from "@assets/images/services/applique/Multi-Media-Applique.JPG";
//@ts-expect-error image extension is correct
