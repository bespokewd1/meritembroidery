---
import BaseLayout from "@layouts/BaseLayout.astro";
import CTA from "@components/CTA.astro";
import Gallery from "@components/Gallery.astro";
import ApplicationLogosCarousel, {
  type AppLogo,
} from "@components/ApplicationLogosCarousel.astro";
import "../styles/global.css";

// import landingImage from "@assets/images/merit-gold.webp";
// import landingImage from "@assets/images/merit-dark-gold.webp";
import landingImage from "@assets/images/merit-dark-gold.png";
import ogImage from "@assets/images/merit-cta.webp";

import { getImage, Image } from "astro:assets";
import { TimelineSection } from "@components/TimelineSection";
import LandingTitle from "@components/LandingTitle.astro";
import { getCalculatedWidth } from "@utils/utils";
const optimizedImage = await getImage({ src: landingImage, format: "avif" });

import gallery1 from "@assets/images/gallery/about/1.webp";
import gallery2 from "@assets/images/gallery/about/2.webp";
import gallery3 from "@assets/images/gallery/about/3.webp";
import gallery4 from "@assets/images/gallery/about/4.webp";
import gallery5 from "@assets/images/gallery/about/5.webp";
import gallery6 from "@assets/images/gallery/about/6.webp";
import gallery7 from "@assets/images/gallery/about/7.webp";
import gallery8 from "@assets/images/gallery/about/8.webp";
import { Icon } from "astro-icon/components";

const cards = [
  {
    title: "Our Mission",
    icon: "tabler:target-arrow",
    description:
      "To provide our community and industry with superior-quality custom apparel decorating through expert craftsmanship and innovative decorating techniques, ensuring every stitch and print reflects the excellence our clients deserve. We deliver professional, innovative, and high-impact apparel solutions that foster pride, unity, and a lasting impression.",
  },
  {
    title: "Our Vision",
    icon: "tabler:eye",
    description:
      "To be the most trusted and innovative garment decoration partner in Western Canada, recognized for setting the industry standard in quality, reliability, and creative excellence. To lead the future of apparel branding by integrating cutting-edge technology with traditional craftsmanship, making world-class custom decoration accessible to every brand, team, and business.",
  },
  {
    title: "Our Values",
    icon: "tabler:diamond",
    description:
      "We blend traditional embroidery techniques with modern technology to produce the highest quality apparel, maintaining that high standard on every piece, whether it’s a single sample or a run of 2,000 units. We hit our deadlines so our clients can hit theirs. Our word is our bond.",
  },
  {
    title: "Our Promise",
    icon: "tabler:award",
    description:
      "We promise that every garment leaving our facility will be a 'stitch above' the rest. If it isn't crisp, durable, and exactly to your specifications, we’ll make it right. We promise to provide expert guidance and innovative decorating solutions. You can count on us for transparent communication, on-time delivery, and consistent quality from the first piece to the thousandth.",
  },
];

const TARGET_HEIGHT_PX = 320;

const IMAGES: AppLogo[] = [
  {
    src: gallery1,
    alt: "Gallery Image 1",
    calcWidth: getCalculatedWidth(gallery1, TARGET_HEIGHT_PX),
  },
  {
    src: gallery2,
    alt: "Gallery Image 2",
    calcWidth: getCalculatedWidth(gallery2, TARGET_HEIGHT_PX),
  },
  {
    src: gallery3,
    alt: "Gallery Image 3",
    calcWidth: getCalculatedWidth(gallery3, TARGET_HEIGHT_PX),
  },
  {
    src: gallery4,
    alt: "Gallery Image 4",
    calcWidth: getCalculatedWidth(gallery4, TARGET_HEIGHT_PX),
  },
  {
    src: gallery5,
    alt: "Gallery Image 5",
    calcWidth: getCalculatedWidth(gallery5, TARGET_HEIGHT_PX),
  },
  {
    src: gallery6,
    alt: "Gallery Image 6",
    calcWidth: getCalculatedWidth(gallery6, TARGET_HEIGHT_PX),
  },
  {
    src: gallery7,
    alt: "Gallery Image 7",
    calcWidth: getCalculatedWidth(gallery7, TARGET_HEIGHT_PX),
  },
  {
    src: gallery8,
    alt: "Gallery Image 8",
    calcWidth: getCalculatedWidth(gallery8, TARGET_HEIGHT_PX),
  },
];
---

<BaseLayout
  title="About"
  description="Merit Embroidery is one of the largest wholesale embroidery houses in Western Canada. We have been in the business of apparel decorating for over 20 years."
  preloadedImage={optimizedImage}
  ogImage={ogImage}
>
  <!-- Main About Section Redesign -->
  <section class="bg-bg-light relative overflow-hidden py-16 md:py-24">
    <div class="container mx-auto px-4 md:px-8">
      <LandingTitle title="About Us" />

      <div class="flex flex-col items-center gap-12 lg:flex-row lg:gap-20">
        <div class="flex w-full justify-center lg:w-1/2 lg:justify-end">
          <div class="relative aspect-8/7 w-full max-w-xl">
            <div
              class="border-accent-primary h-full w-full overflow-hidden rounded-t-full border-8 bg-white shadow-xl md:border-12"
            >
              <Image
                src={landingImage}
                class={"h-full w-full object-cover "}
                alt={"merit logo in gold"}
              />
            </div>
          </div>
        </div>

        <div class="text-body-dark w-full space-y-6 lg:w-1/2">
          <h2 class="text-accent-primary text-header font-medium">
            About Merit Embroidery
          </h2>

          <div class="space-y-6 leading-relaxed font-normal">
            <p class="text-body">
              Merit Embroidery is one of the largest wholesale promotional
              decorators in Western Canada. We’ve been in the apparel decorating
              business for over 30 years, proudly serving customers across
              Canada and throughout North America.
            </p>

            <hr class="border-accent-primary/20 w-1/3 border-t-2" />

            <p class="text-body">
              Our extensive experience, combined with state-of-the-art
              machinery, makes us one of the best in the West. With an 11,000
              sq. ft. production facility and warehouse, we’re equipped to
              handle both small and large-volume orders — producing up to 10,000
              decorated garments per day.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="foundation" class="bg-bg-light relative pt-12 pb-24">
    <div
      class="bg-accent-primary absolute inset-0 z-1 mx-auto my-[min(3rem,95%)] max-w-360 rounded-full lg:rounded-[100%]"
    >
    </div>
    <div class="relative z-10 container mx-auto max-w-7xl px-4 py-10 sm:px-10">
      <!-- Section Header -->
      <div class="mb-12 text-center md:mb-16">
        <span
          class="cs-topper text-primary text-topper mt-8 mb-0 block px-10 font-medium tracking-wide uppercase"
        >
          What We Believe In, and Why It Matters
        </span>
        <h2 class="text-header text-body-light font-medium">Our Foundations</h2>
      </div>

      <!-- Cards Grid -->
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
        {
          cards.map((card) => (
            <div
              class:list={[
                "border-accent-primary rounded-3xl border-2 bg-white p-8 text-center shadow-lg transition-transform hover:-translate-y-2",
              ]}
            >
              <div
                class:list={[
                  "text-accent-dark mx-auto mb-6 flex h-20 w-20 items-center justify-center",
                ]}
              >
                <Icon name={card.icon} class="size-20" />
              </div>

              <h3 class="text-accent-dark text-title mb-4 font-medium">
                {card.title}
              </h3>

              <div class="mb-4 h-1 w-full bg-gray-100" />

              <p class="text-body-dark text-body leading-relaxed">
                {card.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <TimelineSection client:visible />

  <ApplicationLogosCarousel
    class="mx-0 -mt-25 mb-15 hidden border-transparent"
    images={IMAGES}
    carouselDuration="20s"
  />
  <CTA />
</BaseLayout>
