---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import CTA from "@components/CTA.astro";
import Landing from "@components/Landing.astro";
import FAQ from "@components/FAQ.astro";
import "../styles/global.css";
import client from "@data/client.json";
import { Icon } from "astro-icon/components";

// Optimize our landing image and pass it as props to the BaseLayout (for preloading) and Landing (for rendering)
import landingImage from "@assets/images/landing.jpg"; // <-- THE PATH TO THE ASSET YOU WANT TO PRELOAD - The asset must live in src
import meritMap from "@assets/images/merit-map.png"; // <-- THE PATH TO THE ASSET YOU WANT TO PRELOAD - The asset must live in src
import { getImage } from "astro:assets";
import MapPinFilled from "@components/MapPinFilled.astro";
import LandingTitle from "@components/LandingTitle.astro";
const optimizedImage = await getImage({ src: landingImage, format: "avif" });

const phoneDisplay = "+1 780-729-0978";
const phoneHref = "tel:+17807290978";
const email = "imassageclinique@gmail.com";
const emailHref = `mailto:${email}`;

const clinicName = client.name || "Merit Embroidery";
const addressOne = client.address.lineOne?.trim() || "10625 40 Ave NW";
const addressTwo = client.address.lineTwo?.trim() || "10625 40 Ave NW";
const phoneNumber = client.phoneForTel?.trim();
const phoneNumber2 = client.phoneForTel2?.trim();
const emailAddress = client.email?.trim() || "10625 40 Ave NW";
const mapHref =
  client.address.mapLink || "https://maps.app.goo.gl/5mASptDbZWLEcpT5A";

const hours = [{ label: "Mon – Fri", value: "8:00 am – 4:30 pm" }];
---

<BaseLayout
  title="Contact"
  description="High-quality in-house embroidery, screen printing, and custom apparel decoration in Edmonton. Serving businesses across Alberta and North America with fast, reliable, and professional service."
  preloadedImage={optimizedImage}
>
  <!-- ============================================ -->
  <!--                    LANDING                   -->
  <!-- ============================================ -->

  <!-- <Landing
    title="About Us"
    image={optimizedImage}
  /> -->

  <!-- ============================================ -->
  <!--                   Contact                    -->
  <!-- ============================================ -->

  <section id="contact-2320">
    <div class="cs-container">
      <div class="cs-content py-0">
        <!-- <span class="cs-topper">Contact Us</span>
        <h2 class="cs-title">Get In Touch With Merit Embroidery</h2> -->
        <LandingTitle title="Contact Us" class="mb-4 md:mb-4" />
        <!--Form-->
        <form
          class="cs-form"
          id="cs-form-323-2320"
          name="Contact Form"
          method="post"
          netlify
        >
          <label class="cs-label text-lg font-medium">
            Name
            <input
              class="cs-input ring-accent-light h-auto p-2 font-medium ring outline-none focus-visible:ring-2"
              required
              type="text"
              name="name"
              placeholder="Name"
            />
          </label>
          <label class="cs-label cs-email text-lg">
            Email
            <input
              class="cs-input ring-accent-light h-auto p-2 font-medium ring outline-none focus-visible:ring-2"
              required
              type="email"
              name="email"
              placeholder="Email"
            />
          </label>
          <label class="cs-label cs-phone w-full text-lg">
            Phone
            <input
              class="cs-input ring-accent-light h-auto p-2 font-medium ring outline-none focus-visible:ring-2"
              required
              type="tel"
              name="phone"
              placeholder="Phone"
            />
          </label>
          <label class="cs-label text-lg">
            Message
            <textarea
              class="cs-textarea cs-input ring-accent-light h-auto p-2 font-medium ring outline-none focus-visible:ring-2"
              required
              name="Message"
              placeholder="Write message..."></textarea>
          </label>
          <button
            class="cs-button-solid bg-accent-primary font-acumin mt-2 mr-0 ml-auto h-auto px-3 py-4 text-xl font-medium tracking-widest uppercase before:rounded-[inherit]"
            type="submit">Send Message</button
          >

          <!-- "cs-button-solid bg-accent-primary font-acumin font-medium", -->
          <!-- <ButtonLink
          class="mt-6 h-auto px-3 py-4 text-xl tracking-widest uppercase"
          href="/get-a-quote"
        >
          Get a Quote
        </ButtonLink> -->
        </form>

        <div class="contact-info flex flex-col gap-4">
          <h2 class="cs-header text-accent-dark text-3xl">Contact Info</h2>

          <div>
            <h3 class="text-accent-dark">ADDRESS</h3>
            <a
              class="group text-accent-dark cs-text mt-1 ml-2 inline-flex items-center gap-2 font-medium transition-colors duration-300 hover:text-red-950 hover:underline"
              href={mapHref}
              target="_blank"
              rel="noopener noreferrer"
            >
              {addressOne}, {addressTwo}
              <Icon
                name="tabler:external-link"
                class={"invisible opacity-0 group-hover:visible transition-[opacity,visibility] group-hover:opacity-100"}
              />
            </a>
          </div>

          <div>
            <h3 class="text-accent-dark">PHONE</h3>
            <a
              class="group cs-text text-accent-dark mt-1 ml-2 inline-flex items-center gap-2 font-medium transition-colors duration-300 hover:text-red-950 hover:underline"
              href={`tel:${phoneNumber}`}
            >
              {client.phoneFormatted}
              <Icon
                name="tabler:external-link"
                class={"invisible opacity-0 group-hover:visible transition-[opacity,visibility] group-hover:opacity-100"}
              />
            </a>
            <a
              class="group cs-text text-accent-dark mt-1 ml-2 inline-flex items-center gap-2 font-medium transition-colors duration-300 hover:text-red-950 hover:underline"
              href={`tel:${phoneNumber2}`}
            >
              {client.phoneFormatted2}
              <Icon
                name="tabler:external-link"
                class={"invisible opacity-0 group-hover:visible transition-[opacity,visibility] group-hover:opacity-100"}
              />
            </a>
          </div>

          <div>
            <h3 class="text-accent-dark">WORKING HOURS</h3>
            <p class="cs-text text-accent-dark mt-1 ml-2 font-medium">
              <strong>Mon - Fri:</strong> 8:00 am – 4:30 pm
            </p>
          </div>

          <div>
            <h3 class="text-accent-dark">EMAIL</h3>

            <a
              class="group cs-text text-accent-dark mt-1 ml-2 inline-flex items-center gap-2 font-medium transition-colors duration-300 hover:text-red-950 hover:underline"
              href={`mailto:${emailAddress}`}
            >
              {emailAddress}
              <Icon
                name="tabler:external-link"
                class={"invisible opacity-0 group-hover:visible transition-[opacity,visibility] group-hover:opacity-100"}
              />
            </a>
          </div>

          <div>
            <h3 class="text-accent-dark">EMPLOYMENT OPPORTUNITIES</h3>
            <p class="cs-text text-accent-dark mt-1 ml-2 font-medium">
              Please submit your resume to:
            </p>

            <a
              class="group cs-text text-accent-dark ml-2 inline-flex items-center gap-2 font-medium transition-colors duration-300 hover:text-red-950 hover:underline"
              href={`mailto:jobs@meritembroidery.com`}
            >
              jobs@meritembroidery.com
              <Icon
                name="tabler:external-link"
                class={"invisible opacity-0 group-hover:visible transition-[opacity,visibility] group-hover:opacity-100"}
              />
            </a>
          </div>
        </div>
      </div>
      <!--Map Image, pin is made in the Figma then export as one image-->
      <div class="cs-map min-h-250">
        <a
          href={mapHref}
          target="_blank"
          rel="noopener noreferrer"
          class="block aspect-9/16 size-full overflow-hidden rounded-tr-[250px] border-t-15 border-r-15 border-[#224ca1]"
        >
          <Image
            src={meritMap}
            alt="merit map in edmonton"
            class="aspect-9/16 size-full scale-102"
          />
        </a>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>

<style lang="less">
  /* PAGE-SPECIFIC STYLES FOR THE ABOUT PAGE */
  /*-- -------------------------- -->
<---          Contact           -->
<--- -------------------------- -*/

  /* Mobile - 360px */
  @media only screen and (min-width: 0rem) {
    #contact-2320 {
      padding: var(--sectionPadding);
      padding-top: 6rem;
      display: flex;
      flex-direction: column;
      /* 48px - 64px */
      gap: clamp(3rem, 6vw, 4rem);
      position: relative;
      z-index: 1;

      .cs-container {
        width: 100%;
        /* changes to 1280px at desktop */
        max-width: (580/16rem);
        margin: auto;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
        /* 48px - 64px */
        gap: clamp(3rem, 6vw, 4rem);
      }

      .cs-container2 {
        width: 100%;
        /* changes to 1280px at desktop */
        max-width: (580/16rem);
        padding: (80/16rem) (48/16rem);
        margin: auto;
        position: relative;
        z-index: 1;

        .cs-topper {
          color: #fff;
        }
      }

      .cs-content {
        text-align: left;
        .contact-info {
          margin-top: 2rem;
          .cs-header {
            color: #000;
          }
          h3 {
            font-weight: 600;
          }
        }
      }

      .cs-title {
        margin-bottom: (32/16rem);
      }

      .cs-form {
        border-radius: (16/16rem);
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        align-items: center;
        gap: (12/16rem);
      }

      .cs-label {
        /* 14px - 16px */
        font-size: clamp(0.875rem, 1.5vw, 1rem);
        width: 100%;
        color: var(--headerColor);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        gap: (4/16rem);
      }

      .cs-input {
        font-size: (16/16rem);
        width: 100%;
        height: (56/16rem);
        padding: 0;
        padding-left: (24/16rem);
        color: var(--headerColor);
        background-color: #f7f7f7;
        border: none;
        /* prevents padding from adding to height and width */
        box-sizing: border-box;
        &::placeholder {
          color: #7d799c;
          opacity: 0.6;
        }
      }

      .cs-textarea {
        min-height: (120/16rem);
        padding-top: (24/16rem);
        margin-bottom: (12/16rem);
        font-family: inherit;
      }

      .cs-button-solid {
        font-size: (16/16rem);
        /* 46px - 56px */
        // line-height: clamp(2.875rem, 5.5vw, 3.5rem);
        text-decoration: none;
        font-weight: 700;
        text-align: center;
        margin: 0;
        color: #fff;
        padding: 0 (24/16rem);
        background-color: var(--primary);
        display: inline-block;
        position: relative;
        z-index: 1;
        /* prevents padding from adding to the width */
        box-sizing: border-box;

        &:before {
          content: "";
          position: absolute;
          height: 100%;
          width: 0%;
          background: #000;
          opacity: 1;
          top: 0;
          left: 0;
          z-index: -1;
          border-radius: (4/16rem);
          transition: width 0.3s;
        }

        &:hover {
          &:before {
            width: 100%;
          }
        }
      }

      // .cs-submit {
      //     text-transform: uppercase;
      //     background-color: var(--secondaryLight);
      //     color: var(--headerColor);
      //     border: none;
      //     transition: color 0.3s;
      //     &:hover {
      //         cursor: pointer;
      //         color: #fff;
      //     }
      // }

      .cs-map {
        width: 100%;
        max-width: (630/16rem);
        height: (400/16rem);
        position: relative;
        z-index: 1;
        display: block;
      }

      .cs-iframe-wrapper {
        width: 100%;
        position: absolute;
        top: 0;
        left: 0;
        /* 40px - 56px */
        bottom: clamp(2.5rem, 5vw, 3.5rem);

        iframe {
          position: absolute;
          top: 0;
          left: 0;
          height: 100%;
          width: 100%;
          object-fit: cover;
        }
      }

      .cs-box {
        width: 90%;
        max-width: (450/16rem);
        /* 16px - 32px top & bottom */
        /* 16px left & right */
        padding: clamp(1rem, 3vw, 2rem) clamp(1rem, 2.4vw, 1rem);
        background-color: #fff;
        display: flex;
        align-items: flex-start;
        gap: (8/16rem);
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        z-index: 100;

        &:before {
          content: "";
          width: 100%;
          height: 100%;
          background: var(--primary);
          pointer-events: none;
          opacity: 0.1;
          display: block;
          position: absolute;
          top: 0;
          left: 0;
          z-index: -1;
        }
      }

      .cs-icon {
        width: (32/16rem);
        height: auto;
        display: block;
      }

      .cs-flex {
        display: flex;
        flex-direction: column;
      }

      .cs-header {
        font-size: (20/16rem);
        font-weight: 700;
        line-height: 1.2em;
        margin: 0 0 (8/16rem);
        color: var(--headerColor);
      }

      .cs-address {
        font-size: clamp(0.75rem, 2.8vw, 1rem);
        line-height: 1.5em;
        margin: 0;
        color: var(--bodyTextColor);
      }

      .cs-hours {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      .cs-hours-info {
        /* 20px - 25px */
        font-size: clamp(1.25rem, 3vw, 1.5625rem);
        line-height: 1.2em;
        font-weight: 700;
        width: 60%;
        max-width: 28ch;
        margin: 0;
        color: var(--bodyTextColorWhite);
      }

      .cs-background {
        width: 100%;
        height: 100%;
        display: block;
        position: absolute;
        top: 0;
        left: 0;
        z-index: -1;

        &:before {
          /* background color overlay */
          content: "";
          position: absolute;
          display: block;
          height: 100%;
          width: 100%;
          background: #000;
          opacity: 0.72;
          top: 0;
          left: 0;
          z-index: 1;
        }

        img {
          position: absolute;
          top: 0;
          left: 0;
          height: 100%;
          width: 100%;
          /* Makes img tag act as a background image */
          object-fit: cover;
        }
      }
    }
  }

  /* Small Desktop - 1024px */
  @media only screen and (min-width: 64rem) {
    #contact-2320 {
      .cs-container {
        max-width: (1280/16rem);
        flex-direction: row;
        justify-content: space-between;
        align-items: stretch;
        gap: (52/16rem);
      }

      .cs-container2 {
        max-width: (1280/16rem);
      }

      .cs-content {
        // order -1 makes it left for desktop
        order: -1;
        max-width: (522/16rem);
        /* 24px - 80px */
        padding: clamp(2rem, 5vw, 5rem) 0;
      }

      .cs-title,
      .cs-topper,
      .cs-text {
        text-align: left;
        margin-left: 0;
      }

      .cs-title {
        max-width: (522/16rem);
      }

      .cs-services,
      .cs-phone {
        width: 47%;
      }

      .cs-button-solid {
        margin-left: 0;
      }

      .cs-map {
        max-width: (630/16rem);
        height: auto;
        order: -1;
      }
    }
  }
</style>
